{
     "Version": "2012-10-17",
     "Statement": [
       {
         "Sid": "SnapshotLifecycle",
         "Effect": "Allow",
         "Action": [
           "ec2:CreateSnapshot",
           "ec2:DescribeSnapshots",
           "ec2:DeleteSnapshot",
           "ec2:CreateTags",
           "ec2:DescribeVolumes"
         ],
         "Resource": "*"
       },
       {
         "Sid": "Logging",
         "Effect": "Allow",
         "Action": [
           "logs:CreateLogGroup",
           "logs:CreateLogStream",
           "logs:PutLogEvents"
         ],
         "Resource": "arn:aws:logs:*:*:*"
       }
     ]
   }